#:kivy 2.3.1

<CandleCard>:
    orientation: "vertical"
    size_hint: None, None
    size: "130dp", "150dp"
    padding: "8dp"
    spacing: "4dp"
    style: "elevated"
    radius: [20, 20, 20, 20]
    on_release: app.select_candle(self.candle_id)

    MDIcon:
        icon: root.icon_source
        font_size: "64sp"
        pos_hint: {"center_x": .5}
        theme_text_color: "Custom"
        text_color: root.icon_color
        size_hint_y: 0.65
    
    MDLabel:
        text: root.candle_name
        halign: "center"
        font_style: "Title"
        role: "medium"
        theme_text_color: "Primary"
        size_hint_y: 0.2
        
    MDLabel:
        text: root.candle_time
        halign: "center"
        font_style: "Label"
        role: "medium"
        theme_text_color: "Secondary"
        size_hint_y: 0.15

<ScreenManager>:
    HearthScreen:
        name: 'hearth'
    WaxShopScreen:
        name: 'shop'
    GraveyardScreen:
        name: 'graveyard'

<HearthScreen>:
    MDBoxLayout:
        orientation: 'vertical'

        MDTopAppBar:
            type: "small"
            MDTopAppBarTitle:
                text: "The Hearth"
            MDTopAppBarTrailingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "cart-outline"
                    on_release: root.manager.current = 'shop'
                MDActionTopAppBarButton:
                    icon: "history"
                    on_release: root.manager.current = 'graveyard'
        
        MDBoxLayout:
            orientation: 'vertical'
            padding: "10dp"
            spacing: "5dp"
            
            MDScrollView:
                size_hint_y: None
                height: "170dp"
                do_scroll_y: False
                do_scroll_x: True
                MDBoxLayout:
                    id: candle_carousel
                    orientation: "horizontal"
                    adaptive_width: True
                    spacing: "15dp"
                    padding: ["10dp", "10dp", "10dp", "10dp"]

            MDLabel:
                id: selected_candle_label
                text: "Select a candle to begin"
                font_style: "Title"
                role: "large"
                halign: "center"
                theme_text_color: "Primary"
                size_hint_y: None
                height: "30dp"

            MDLabel:
                id: timer_label
                text: "00:00"
                font_style: "Display"
                role: "large"
                theme_text_color: "Primary"
                font_size: "64sp"
                bold: True
                halign: "center"
                size_hint_y: None
                height: "80dp"

            Candle:
                id: candle_widget
                size_hint_y: 1

            MDBoxLayout:
                adaptive_height: True
                spacing: "20dp"
                padding: "20dp"
                pos_hint: {"center_x": 0.5}

                MDButton:
                    id: start_btn
                    style: "filled"
                    on_release: root.start_timer()
                    MDButtonText:
                        text: "Light Flame"

                MDButton:
                    id: pause_btn
                    style: "tonal"
                    disabled: True
                    on_release: root.pause_timer()
                    MDButtonText:
                        id: pause_btn_text
                        text: "Pause"

<ShopCard>:
    orientation: "vertical"
    size_hint_y: None
    height: "220dp"
    padding: "10dp"
    spacing: "5dp"
    style: "elevated"
    radius: [20, 20, 20, 20]
    
    MDIcon:
        icon: root.icon_source
        font_size: "64sp"
        pos_hint: {"center_x": .5}
        theme_text_color: "Custom"
        text_color: root.icon_color
        size_hint_y: 0.5
        
    MDLabel:
        text: root.candle_name
        halign: "center"
        font_style: "Title"
        role: "medium"
        theme_text_color: "Primary"
        size_hint_y: None
        height: "30dp"
        
    MDButton:
        pos_hint: {"center_x": .5}
        style: "filled"
        on_release: root.shop_screen.buy_candle(root.candle_id, root.candle_price)
        MDButtonText:
            text: "Buy (" + str(root.candle_price) + ")"

<WaxShopScreen>:
    MDBoxLayout:
        orientation: 'vertical'
        MDTopAppBar:
            type: "small"
            MDTopAppBarLeadingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "arrow-left"
                    on_release: root.manager.current = 'hearth'
            MDTopAppBarTitle:
                text: "The Wax Shop"
                
        MDBoxLayout:
            orientation: 'horizontal'
            adaptive_height: True
            padding: "20dp"
            
            MDLabel:
                id: balance_label
                text: "Embers: 0"
                font_style: "Title"
                role: "large"
                
            MDButton:
                style: "tonal"
                pos_hint: {"center_y": .5}
                on_release: root.manager.current = 'forge'
                MDButtonText:
                    text: "Enter Forge (Cost: 5)"
        
        MDScrollView:
            MDGridLayout:
                id: shop_grid
                cols: 2
                adaptive_height: True
                padding: ["20dp", "10dp", "20dp", "20dp"]
                spacing: "15dp"

<ForgeScreen>:
    MDBoxLayout:
        orientation: 'vertical'
        MDTopAppBar:
            type: "small"
            MDTopAppBarLeadingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "arrow-left"
                    on_release: root.manager.current = 'shop'
            MDTopAppBarTitle:
                text: "The Forge"
                
        MDLabel:
            text: "Draw your custom candle outline!"
            halign: "center"
            font_style: "Title"
            role: "medium"
            size_hint_y: None
            height: "50dp"
            
        MDLabel:
            id: forge_bal
            text: "Balance: 0 Embers"
            halign: "center"
            theme_text_color: "Secondary"
            size_hint_y: None
            height: "30dp"
            
        MDBoxLayout:
            padding: "20dp"
            DrawCanvas:
                id: draw_area
                
        MDBoxLayout:
            size_hint_y: None
            height: "80dp"
            padding: "20dp"
            spacing: "20dp"
            
            MDButton:
                style: "text"
                on_release: draw_area.clear_canvas()
                MDButtonText:
                    text: "Clear"
                    
            MDButton:
                style: "filled"
                on_release: root.forge_candle()
                MDButtonText:
                    text: "Forge Candle"

<GraveyardScreen>:
    MDBoxLayout:
        orientation: 'vertical'
        MDTopAppBar:
            type: "small"
            MDTopAppBarLeadingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "arrow-left"
                    on_release: root.manager.current = 'hearth'
            MDTopAppBarTitle:
                text: "The Graveyard"
                
        MDScrollView:
            MDList:
                id: sessions_list